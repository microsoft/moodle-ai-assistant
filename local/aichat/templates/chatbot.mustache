{{! Floating Action Button }}
<button id="aichat-fab" class="aichat-fab" aria-label="{{#str}}courseassistant, local_aichat{{/str}}" title="{{#str}}courseassistant, local_aichat{{/str}}">
    {{#avatarUrl}}
        <img src="{{avatarUrl}}" alt="" class="aichat-fab-avatar" />
    {{/avatarUrl}}
    {{^avatarUrl}}
        <svg class="aichat-fab-icon" viewBox="0 0 48 48" width="28" height="28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="24" y1="4" x2="24" y2="9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="24" cy="3" r="2" fill="currentColor"/>
            <rect x="6" y="9" width="36" height="26" rx="7" ry="7" fill="currentColor"/>
            <rect x="10" y="14" width="28" height="16" rx="4" ry="4" fill="white" opacity="0.15"/>
            <circle cx="17" cy="22" r="3" fill="white"/>
            <circle cx="18" cy="21" r="1.2" fill="currentColor"/>
            <circle cx="31" cy="22" r="3" fill="white"/>
            <circle cx="32" cy="21" r="1.2" fill="currentColor"/>
            <path d="M18 28 Q24 32.5 30 28" stroke="white" stroke-width="1.8" fill="none" stroke-linecap="round"/>
            <rect x="2" y="17" width="5" height="7" rx="2" ry="2" fill="currentColor" opacity="0.7"/>
            <rect x="41" y="17" width="5" height="7" rx="2" ry="2" fill="currentColor" opacity="0.7"/>
            <rect x="19" y="35" width="10" height="4" rx="2" ry="2" fill="currentColor" opacity="0.8"/>
            <rect x="12" y="39" width="24" height="6" rx="3" ry="3" fill="currentColor"/>
        </svg>
    {{/avatarUrl}}
</button>

{{! Chat Panel }}
<div id="aichat-panel" class="aichat-panel aichat-hidden" role="dialog" aria-label="{{#str}}courseassistant, local_aichat{{/str}}">

    {{! Header }}
    <div class="aichat-header">
        <div class="aichat-header-left">
            {{#avatarUrl}}
                <img src="{{avatarUrl}}" alt="" class="aichat-header-avatar" />
            {{/avatarUrl}}
            {{^avatarUrl}}
                <div class="aichat-header-avatar aichat-header-avatar-default">
                    <svg viewBox="0 0 48 48" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <line x1="24" y1="4" x2="24" y2="9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="24" cy="3" r="2" fill="currentColor"/>
                        <rect x="6" y="9" width="36" height="26" rx="7" ry="7" fill="currentColor"/>
                        <rect x="10" y="14" width="28" height="16" rx="4" ry="4" fill="white" opacity="0.15"/>
                        <circle cx="17" cy="22" r="3" fill="white"/>
                        <circle cx="18" cy="21" r="1.2" fill="currentColor"/>
                        <circle cx="31" cy="22" r="3" fill="white"/>
                        <circle cx="32" cy="21" r="1.2" fill="currentColor"/>
                        <path d="M18 28 Q24 32.5 30 28" stroke="white" stroke-width="1.8" fill="none" stroke-linecap="round"/>
                        <rect x="2" y="17" width="5" height="7" rx="2" ry="2" fill="currentColor" opacity="0.7"/>
                        <rect x="41" y="17" width="5" height="7" rx="2" ry="2" fill="currentColor" opacity="0.7"/>
                        <rect x="19" y="35" width="10" height="4" rx="2" ry="2" fill="currentColor" opacity="0.8"/>
                        <rect x="12" y="39" width="24" height="6" rx="3" ry="3" fill="currentColor"/>
                    </svg>
                </div>
            {{/avatarUrl}}
            <span class="aichat-header-title">{{headerTitle}}</span>
        </div>
        <div class="aichat-header-right">
            {{#enableExport}}
                <button id="aichat-export-btn" class="aichat-header-btn" aria-label="{{#str}}exportchat, local_aichat{{/str}}" title="{{#str}}exportchat, local_aichat{{/str}}">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                </button>
            {{/enableExport}}
            <button id="aichat-newchat-btn" class="aichat-header-btn" aria-label="{{#str}}newchat, local_aichat{{/str}}" title="{{#str}}newchat, local_aichat{{/str}}">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
            </button>
            <button id="aichat-close-btn" class="aichat-header-btn" aria-label="{{#str}}close, local_aichat{{/str}}" title="{{#str}}close, local_aichat{{/str}}">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
    </div>

    {{! Messages Area }}
    <div id="aichat-messages" class="aichat-messages" role="log" aria-live="polite">
        {{! Welcome state with action cards — shown initially, removed when history loads }}
        <div id="aichat-welcome" class="aichat-welcome">
            <div class="aichat-action-cards">
                <button class="aichat-action-card" data-action="tellmeaboutcourse">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    <span>{{#str}}tellmeaboutcourse, local_aichat{{/str}}</span>
                </button>
                <button class="aichat-action-card" data-action="summarizesection">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                    <span>{{#str}}summarizesection, local_aichat{{/str}}</span>
                </button>
                <button class="aichat-action-card" data-action="createquiz">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <span>{{#str}}createquiz, local_aichat{{/str}}</span>
                </button>
            </div>
        </div>

        {{! Typing indicator (hidden by default) }}
        <div id="aichat-typing" class="aichat-typing aichat-hidden" aria-label="{{#str}}thinking, local_aichat{{/str}}">
            <div class="aichat-bubble aichat-bubble-assistant">
                <div class="aichat-typing-dots">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
    </div>

    {{! Upload preview area (hidden by default) }}
    <div id="aichat-upload-preview" class="aichat-upload-preview aichat-hidden"></div>

    {{! Input Area }}
    <div class="aichat-input-area">
        <div class="aichat-input-row">
            {{#enableUpload}}
                <button id="aichat-upload-btn" class="aichat-upload-btn" aria-label="{{#str}}uploaddocument, local_aichat{{/str}}" title="{{#str}}uploaddocument, local_aichat{{/str}}">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                    </svg>
                </button>
            {{/enableUpload}}
            <textarea id="aichat-input" class="aichat-input" rows="1"
                      placeholder="{{#str}}typemessage, local_aichat{{/str}}"
                      maxlength="{{maxMsgLength}}"
                      aria-label="{{#str}}sendmessage, local_aichat{{/str}}"></textarea>
            <button id="aichat-mic-btn" class="aichat-mic-btn aichat-hidden" aria-label="{{#str}}voiceinput, local_aichat{{/str}}" title="{{#str}}voiceinput, local_aichat{{/str}}">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                </svg>
            </button>
            <button id="aichat-send-btn" class="aichat-send-btn" disabled aria-label="{{#str}}sendmessage, local_aichat{{/str}}">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            </button>
        </div>
        <div id="aichat-daily-limit" class="aichat-daily-limit"></div>
    </div>

    {{! Privacy Notice Overlay (hidden by default) }}
    {{#showPrivacyNotice}}
        <div id="aichat-privacy-overlay" class="aichat-privacy-overlay aichat-hidden">
            <div class="aichat-privacy-card">
                <h3>{{#str}}privacynoticetitle, local_aichat{{/str}}</h3>
                <div class="aichat-privacy-text">{{{privacyNotice}}}</div>
                <button id="aichat-privacy-agree" class="aichat-privacy-agree-btn">
                    {{#str}}iagree, local_aichat{{/str}}
                </button>
            </div>
        </div>
    {{/showPrivacyNotice}}
</div>
